// src/test/java/IntQueueTest.java
import org.junit.jupiter.api.*;
import static org.junit.jupiter.api.Assertions.*;
public class IntQueueTest {
    private IntQueue queue;
    @BeforeEach
    public void setUp() {
        queue = new ArrayIntQueue();
    }
    @Test
    @DisplayName("Шинээр үүссэн queue хоосон байх ёстой")
    public void testNewQueueIsEmpty() {
        assertTrue(queue.isEmpty());
        assertEquals(0, queue.size());
    }
    @Test
    @DisplayName("enqueue хийсний дараа queue хоосон биш болно")
    public void testEnqueueMakesNotEmpty() {
        queue.enqueue(10);
        assertFalse(queue.isEmpty());
        assertEquals(1, queue.size());
    }
    @Test
    @DisplayName("enqueue, dequeue дарааллын зарчмаар ажиллах")
    public void testFifoOrder() {
        queue.enqueue(10);
        queue.enqueue(20);
        queue.enqueue(30);
        assertEquals(10, queue.dequeue());
        assertEquals(20, queue.dequeue());
        assertEquals(30, queue.dequeue());
        assertTrue(queue.isEmpty());
    }
    @Test
    @DisplayName("peek() хамгийн урд талын элементийг буцаах боловч устгахгүй")
    public void testPeek() {
        queue.enqueue(10);
        queue.enqueue(20);
        
        assertEquals(10, queue.peek());
        assertEquals(10, queue.peek());
        assertEquals(2, queue.size());
    }
    @Test
    @DisplayName("clear() дарааллыг цэвэрлэх")
    public void testClear() {
        queue.enqueue(10);
        queue.enqueue(20);
        queue.enqueue(30);
        queue.clear();
        assertTrue(queue.isEmpty());
        assertEquals(0, queue.size());
    }
    @Test
    @DisplayName("Хоосон queue-с dequeue хийхэд exception шидэгдэнэ")
    public void testDequeueOnEmptyThrowsException() {
        assertThrows(IllegalStateException.class, () -> queue.dequeue());
    }
    @Test
    @DisplayName("Хоосон queue-с peek хийхэд exception шидэгдэнэ")
    public void testPeekOnEmptyThrowsException() {
        assertThrows(IllegalStateException.class, () -> queue.peek());
    }
    @Test
    @DisplayName("Resize-ийн үед зөв ажиллах")
    public void testResize() {
        for (int i = 0; i < 20; i++) {
            queue.enqueue(i);
        }
        assertEquals(20, queue.size());
        for (int i = 0; i < 10; i++) {
            assertEquals(i, queue.dequeue());
        }
        for (int i = 20; i < 30; i++) {
            queue.enqueue(i);
        }
        assertEquals(20, queue.size());
        assertEquals(10, queue.dequeue());
    }
    @Test
    @DisplayName("Сөрөг capacity-ээр үүсгэхэд exception шидэгдэнэ")
    public void testNegativeCapacityThrowsException() {
        assertThrows(IllegalArgumentException.class, () -> new ArrayIntQueue(-5));
    }
}
