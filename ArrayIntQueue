public class ArrayIntQueueFixed implements IntQueue {
    private int[] array;
    private int front;
    private int rear;
    private int count;
    private int capacity;
    public ArrayIntQueueFixed() {
        this(10);
    }
    public ArrayIntQueueFixed(int initialCapacity) {
        if (initialCapacity <= 0) {
            throw new IllegalArgumentException("Capacity must be positive");
        }
        this.capacity = initialCapacity;
        array = new int[capacity];
        front = 0;
        rear = -1;
        count = 0;
    }
    @Override
    public void enqueue(int value) {
        if (count == capacity) {
            resize();
        }
        rear = (rear + 1) % capacity;
        array[rear] = value;
        count++;
    }
    @Override
    public int dequeue() {
        if (isEmpty()) {
            throw new IllegalStateException("Queue is empty");
        }
        int value = array[front];
        front = (front + 1) % capacity;
        count--;
        return value;
    }
    @Override
    public int peek() {
        if (isEmpty()) {
            throw new IllegalStateException("Queue is empty");
        }
        return array[front];
    }
    @Override
    public boolean isEmpty() {
        return count == 0;
    }
    @Override
    public int size() {
        return count;
    }
    @Override
    public void clear() {
        // ЗАССАН: array-г цэвэрлэх
        array = new int[capacity];
        front = 0;
        rear = -1;
        count = 0;
    }
    private void resize() {
        int newCapacity = capacity * 2;
        int[] newArray = new int[newCapacity];   
        // ЗАССАН: элементүүдийг зөв дарааллаар хуулах
        for (int i = 0; i < count; i++) {
            newArray[i] = array[(front + i) % capacity];
        }
        array = newArray;
        front = 0;
        rear = count - 1;
        capacity = newCapacity;
    }
}
